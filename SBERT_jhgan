import pandas as pd
import numpy as np
import os
from sentence_transformers import SentenceTransformer
from scipy.cluster.hierarchy import linkage, fcluster
from sklearn.preprocessing import normalize
from sklearn.metrics import silhouette_score
from collections import defaultdict
import umap.umap_ as umap
from sklearn.metrics.pairwise import cosine_similarity
from google.colab import drive

# 2. 드라이브 마운트
drive.mount('/content/drive')

# Configuration
INPUT_FILE_PATH = '/content/drive/MyDrive/복지/김보현/휴먼전처리/def3_fill.csv'
OUTPUT_DIR = '/content/drive/MyDrive/복지/김보현/계층적cluster'

TARGET_CLUSTER_COUNTS = [100, 200, 300, 400]

# Weights
WEIGHT_DD = 0.9
WEIGHT_WW = 0.1

def main():
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    # 데이터 로드
    print(f"Loading data from: {INPUT_FILE_PATH}")
    if os.path.exists(INPUT_FILE_PATH):
        raw_df = pd.read_csv(INPUT_FILE_PATH)
        words = raw_df['Words'].fillna('').tolist()
        definitions = raw_df['Definitions'].fillna('').tolist()
        print(f"Total records: {len(words)}")
    else:
        print("Error: File not found.")
        return

    # 모델 준비 (Okt 미사용, 원문 그대로 사용)
    print("Loading SentenceTransformer model...")
    model = SentenceTransformer('jhgan/ko-sroberta-multitask')

    # 임베딩 생성
    print("Generating text embeddings...")
    emb_def = model.encode(definitions)
    emb_word = model.encode(words)

    # 가중치 결합 및 정규화
    print("Combining and normalizing vectors...")
    weighted = (emb_def * WEIGHT_DD) + (emb_word * WEIGHT_WW)
    norm_vectors = normalize(weighted)

    # UMAP 차원 축소
    print("Applying UMAP...")
    reducer = umap.UMAP(
        n_neighbors=10, 
        min_dist=0.0, 
        n_components=5, 
        metric='cosine', 
        random_state=42
    )
    final_vectors = reducer.fit_transform(norm_vectors)
    print(f"UMAP shape: {final_vectors.shape}")

    # 계층적 클러스터링
    print("Calculating hierarchical clustering (Ward)...")
    Z = linkage(final_vectors, method='ward')

    print("\n--- Clustering Evaluation ---")

    for n_clusters in TARGET_CLUSTER_COUNTS:
        labels = fcluster(Z, n_clusters, criterion='maxclust')

        # 실루엣 스코어 계산
        try:
            sil_score = silhouette_score(final_vectors, labels, metric='euclidean')
        except Exception:
            sil_score = -1

        # 응집도 계산
        cohesions = []
        unique_labels = np.unique(labels)

        for label in unique_labels:
            indices = np.where(labels == label)[0]

            if len(indices) < 2:
                cohesions.append(1.0)
                continue

            group_vecs = final_vectors[indices]
            sim_mat = cosine_similarity(group_vecs)
            np.fill_diagonal(sim_mat, np.nan)
            cohesions.append(np.nanmean(sim_mat))

        avg_cohesion = np.mean(cohesions)

        print(f"K={n_clusters:<4} | Silhouette: {sil_score:.4f} | Cohesion: {avg_cohesion:.4f}")

        # 결과 저장 (실루엣 스코어 0.4 이상)
        if sil_score >= 0.4:
            cluster_map = defaultdict(list)
            for w, l in zip(words, labels): 
                cluster_map[l].append(w)

            output_rows = []
            for cid, wlist in cluster_map.items():
                output_rows.append({
                    'cluster_id': cid,
                    'cluster_words': ', '.join(wlist),
                    'count': len(wlist)
                })

            file_name = f'hi_Best_K{n_clusters}_Sil{sil_score:.2f}_NoOkt.csv'
            save_path = os.path.join(OUTPUT_DIR, file_name)
            
            result_df = pd.DataFrame(output_rows)
            # cluster_id 기준으로 정렬
            result_df = result_df.sort_values(by='cluster_id') 
            result_df.to_csv(save_path, index=False, encoding='utf-8-sig')
            
            print(f"  -> Saved: {file_name}")
        else:
            print(f"  -> Skipped (Silhouette < 0.40)")

if __name__ == "__main__":
    main()
